#!/bin/bash

function generate_password() {
    openssl rand -base64 40
}

function gk() {
    gitk --all . & disown
}

function skim() {
    sk \
        --ansi \
        --delimiter : \
        --layout=reverse-list \
        -i \
        -c 'rg --color=always --line-number "{}"' \
        --preview 'bat --color=always --theme 1337 --style=numbers --highlight-line {2} {1}' \
        --preview-window "+{2}-/2" \
        --bind 'ctrl-y:execute-silent(code --goto {1}:{2})+abort'
}

function reset_git() {
    git submodule deinit --all -f
    git submodule update --init --recursive
}

function pubip() {
    curl https://ipinfo.io/ip
}

# docker functions
_d() {
    local -a subcmds
    subcmds=(
        'ps:list all docker containers'
        'rmall:force-remove all containers'
        'vrmall:force-remove all volumes'
        'lsv:list volumes with sizes'
    )
    _describe 'd subcommand' subcmds
}
compdef _d d

function d() {
    case "$1" in
        ps) docker ps -a ;;
        rmall) docker ps -aq | xargs -n1 docker rm -f ;;
        vrmall) docker volume ls -q | xargs -n1 docker volume rm -f ;;
        lsv) docker system df -v | awk '/^VOLUME NAME/{found=1; print "VOLUME\t\t\t\tSIZE"; next} found && /^$/{exit} found{printf "%-40s %s\n", $1, $NF}' ;;
        *) echo "Unknown command: d $1"; return 1 ;;
    esac
}

function gh_cancel_queued() {
    gh run list --status queued --json databaseId --jq '.[].databaseId' | xargs -I {} gh run cancel {}
}

function gh_cancel_in_progress() {
    gh run list --status in_progress --json databaseId --jq '.[].databaseId' | xargs -I {} gh run cancel {}
}


  gh() {
    if [[ -t 0 && "$1" == "pr" && "$2" == "create" ]]; then
      command gh "$@" || return $?

      # gh pr view (no args) resolves the PR for the current branch.
      local pr_number
      pr_number=$(command gh pr view --json number --jq .number 2>/dev/null) || return 0
      [[ -z "$pr_number" ]] && return 0

      _gh_post_create_link "$pr_number"
      return 0
    fi

    command gh "$@"
  }
  _gh_post_create_link() {
    local pr_number=$1

    printf 'tie this PR to an issue? [y/N] '
    local confirm
    read -r confirm
    [[ "$confirm" =~ ^[Yy]$ ]] || return 0

    command -v fzf >/dev/null || { echo "fzf not installed; skipping" >&2; return 0; }

    local selected
    selected=$(command gh issue list --state open --limit 200 \
                --json number,title \
                --jq '.[] | "#\(.number)\t\(.title)"' \
              | fzf --prompt="link issue> " --height=40% --reverse)
    [[ -z "$selected" ]] && return 0

    local issue_number existing_body
    issue_number=$(printf '%s' "$selected" | sed -E 's/^#([0-9]+).*/\1/')
    existing_body=$(command gh pr view "$pr_number" --json body --jq .body)

    command gh pr edit "$pr_number" --body "${existing_body}

  Closes #${issue_number}"

    echo "linked PR #${pr_number} → issue #${issue_number}"
  }


dotenv() {
  command -v fzf >/dev/null || { echo "fzf not installed" >&2; return 1; }

  local file
  file=$(find . -maxdepth 1 -type f -name '.env*' | sed 's|^\./||' | sort \
         | fzf --prompt="dotenv> " --height=40% --reverse --select-1 \
               --preview 'cat {}')
  [ -z "$file" ] && return 0

  set -a
  # shellcheck disable=SC1090
  source "./$file"
  set +a
  echo "sourced $file"
}

whoport() {
  if [ -z "$1" ]; then
    echo "Usage: whoport <port>"
    return 1
  fi

  if [ "$(uname)" = "Darwin" ]; then
    sudo lsof -nP -iTCP:"$1" -sTCP:LISTEN
  elif [ "$(uname)" = "Linux" ]; then
    sudo ss -ltnp "sport = :$1"
  else
    echo "Unsupported OS: $(uname)"
    return 1
  fi
}